# --- tatanka3 backend (Laravel) ---
# Base URL of the backend API. SERVER-ONLY: never exposed to the browser.
# The frontend is a pure API client and never connects to Postgres directly.
# App host (health, /admin, storefront API): https://tatanka3.stiamolavorando.net
# OCTO partner API (JWT, NOT the storefront): https://api.tatanka3.stiamolavorando.net/octo
BACKEND_API_URL=https://tatanka3.stiamolavorando.net

# --- Frontend ---
# Public site URL (absolute links, metadata, sitemap). Safe to expose.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Checkout / payments ---
# Storefront payment gateway. SERVER-ONLY (never NEXT_PUBLIC_*).
#   none   (default) → secure preview: a mock order is created, nothing is charged.
#   redsys           → Redsys InSite hosted card form. Requires the backend storefront
#                      payment endpoints to be live (order + start/authorize); falls back
#                      to the preview automatically if they are unreachable.
# See docs/redsys-insite-sandbox-runbook.md and src/lib/checkout/server.ts.
CHECKOUT_PAYMENT_PROVIDER=none
